# ============================================================================
# ECONSCOPE — API Key Registry
# ============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Keys are loaded by econscope at runtime via python-dotenv.
# NEVER commit .env to git. It's in .gitignore.
#
# Priority levels:
#   P0 = core macro data, get these first
#   P1 = important, unlocks major capabilities
#   P2 = enhances depth, get when needed
#   P3 = nice-to-have, optional
# ============================================================================

# ── P0: CORE MACRO/ECONOMIC ─────────────────────────────────────────────────

# FRED (Federal Reserve Economic Data) — 800K+ time series
# Register: https://research.stlouisfed.org/useraccount/apikeys
FRED_API_KEY=

# BLS (Bureau of Labor Statistics) — CPI, employment, wages, JOLTS
# Register: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# BEA (Bureau of Economic Analysis) — GDP, PCE, personal income, IO tables
# Register: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# ── P1: IMPORTANT EXTENSIONS ────────────────────────────────────────────────

# US Census Bureau — ACS demographics, County Business Patterns, trade
# Register: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# EIA (Energy Information Administration) — oil, gas, electricity, renewables
# Register: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# UK Companies House — company filings, officers, PSCs, charges
# Register: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# USDA NASS (Ag statistics) — production, prices, land use by county
# Register: https://quickstats.nass.usda.gov/api/
USDA_NASS_API_KEY=

# ── P2: FINANCIAL MARKET DATA ───────────────────────────────────────────────

# Finnhub — real-time quotes, insider transactions, ESG, SEC filings parsed
# Register: https://finnhub.io/register
# Free: 60 calls/min
FINNHUB_API_KEY=

# Financial Modeling Prep — income statements, balance sheets, ratios, DCF
# Register: https://site.financialmodelingprep.com/developer/docs
# Free: 250 calls/day
FMP_API_KEY=

# Alpha Vantage — historical prices, forex, crypto, economic indicators
# Register: https://www.alphavantage.co/support/#api-key
# Free: 25 calls/day (paid: 75/min at $50/mo)
ALPHA_VANTAGE_KEY=

# Polygon.io — tick-level stocks, options, forex, crypto
# Register: https://polygon.io/dashboard/signup
# Free: 5 calls/min
POLYGON_API_KEY=

# Tiingo — clean historical prices, fundamentals, news with sentiment
# Register: https://www.tiingo.com/account/api/token
# Free: 1000 unique symbols/month
TIINGO_API_KEY=

# IEX Cloud — US equities, fundamentals, CEO comp
# Register: https://iexcloud.io/cloud-login#/register
IEX_CLOUD_API_KEY=

# ── P2: CORPORATE/LEGAL OSINT ──────────────────────────────────────────────

# OpenCorporates — corporate registry data from 170+ jurisdictions
# Register: https://opencorporates.com/api_accounts/new
# Free tier available
OPENCORPORATES_API_TOKEN=

# OpenSanctions — sanctions, PEPs, entities of interest
# Register: https://www.opensanctions.org/api/
# Free for non-commercial
OPENSANCTIONS_API_KEY=

# CourtListener / RECAP — US court opinions, PACER dockets
# Register: https://www.courtlistener.com/api/rest-info/
# Free
COURTLISTENER_API_TOKEN=

# ── P2: INTERNATIONAL ───────────────────────────────────────────────────────

# UN Comtrade — bilateral trade flows, HS6 detail
# Register: https://comtradeplus.un.org/
# Free: limited calls
COMTRADE_API_KEY=

# ── P3: NOTIFICATIONS ───────────────────────────────────────────────────────

# Pushover — push notifications to phone/desktop
# Register: https://pushover.net/
# One-time $5 per platform
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# ── P3: AI/NLP (for entity extraction, summarization) ──────────────────────

# Anthropic (Claude API) — for NLP tasks within the pipeline
# Already have this if you're using Claude Code
ANTHROPIC_API_KEY=

# ── NO KEY NEEDED (documented here for reference) ───────────────────────────
# These work without registration. Listed so you know they exist.
#
# SEC EDGAR / EFTS         — Full-text search + XBRL. 10 req/sec with User-Agent.
# DBnomics                 — Aggregates 70+ providers. No limits.
# IMF (WEO, IFS, DOTS)     — World Economic Outlook, financial stats, trade.
# World Bank (WDI)          — 16,000+ development indicators.
# OECD (STAN, MEI, TiVA)   — Structural analysis, leading indicators, value-added trade.
# Eurostat                  — EU-wide economic/social/trade data.
# ECB Statistical DW        — Euro area monetary, credit, securities.
# Bank of England           — Rates back to 1694, monetary aggregates.
# UK ONS                    — GDP, CPI, labour, trade, regional.
# Treasury FiscalData       — Debt, auctions, spending, revenue, FX.
# FHFA (House Price Index)  — HPI by state, metro, zip.
# FDIC BankFind Suite       — Every FDIC bank's financials, branches.
# CFTC (Commitments of Traders) — Futures positioning data (CSV download).
# CFPB Complaint Database   — 4M+ consumer complaints by company.
# USPTO PatentsView         — Patent grants, citations, assignees.
# OpenAlex                  — Scholarly works, authors, institutions.
# Semantic Scholar          — Paper search, citation graph.
# Wikidata SPARQL           — Structured entity data.
# GDELT 2.0                 — Global news events, tone, network.
# LittleSis                 — Power/influence network database.
# Penn World Table          — GDP, capital, productivity, 183 countries.
# Maddison Project          — Historical GDP per capita.
# SIPRI                     — Military expenditure, arms transfers.
# ILO (ILOSTAT)             — Employment, wages, 189 countries.
# UNCTAD                    — FDI flows, investment treaties.
# BIS                       — Central bank stats, cross-border banking.
# arXiv (econ section)      — Preprints.
# NBER                      — Working papers (free since 2021).
# Bundesbank                — German/Euro time series.
# Bank of Japan             — Japanese economic data.

# ============================================================================
# ADDING NEW SOURCES
# ============================================================================
# To add a new API source:
# 1. Add the key here with registration URL and tier
# 2. Add an adapter in econscope/adapters/
# 3. Add rate limits to sources.yaml
# 4. Add to the catalog builder in catalog/build_catalog.py
# 5. Run: econscope verify-keys
# ============================================================================
